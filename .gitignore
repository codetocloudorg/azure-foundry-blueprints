# ============================================
# Azure Foundry Blueprints - .gitignore
# ============================================

# --------------------
# Terraform
# --------------------
.terraform/
**/.terraform/
*.tfstate
*.tfstate.*
*.tfstate.backup
.terraform.lock.hcl
**/.terraform.lock.hcl
*.tfplan
**/tfplan
tfplan
crash.log
crash.*.log
override.tf
override.tf.json
*_override.tf
*_override.tf.json
.terraformrc
terraform.rc

# Terraform variable files that might contain secrets
*.auto.tfvars
*.auto.tfvars.json
# Keep dev.tfvars as it contains no secrets
!dev.tfvars

# --------------------
# Bicep
# --------------------
*.json.lock

# --------------------
# Azure CLI
# --------------------
.azure/

# --------------------
# Secrets & Credentials (NEVER commit these)
# --------------------
.env
.env.*
*.env
.env.local
.env.*.local
*.pem
*.key
*.p12
*.pfx
*.crt
*credentials*
*secrets*
service-principal.json
azureauth.json

# --------------------
# OS Files
# --------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
*.swp
*.swo
*~
\#*\#

# --------------------
# IDE & Editors
# --------------------
.vscode/
!.vscode/extensions.json
!.vscode/settings.json.template
.idea/
*.code-workspace
*.sublime-project
*.sublime-workspace
.project
.classpath
.settings/
*.iml

# --------------------
# Logs
# --------------------
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# --------------------
# Build Outputs
# --------------------
dist/
build/
out/
bin/
obj/
target/
node_modules/

# --------------------
# Python (if any scripts use it)
# --------------------
__pycache__/
*.py[cod]
*$py.class
.Python
*.egg-info/
.eggs/
venv/
.venv/
ENV/

# --------------------
# Temporary Files
# --------------------
*.tmp
*.temp
*.bak
*.backup
tmp/
temp/
